@model peakmotion.ViewModels.ProductVM

@{
    ViewData["Title"] = "Product Edit";
}

<link rel="stylesheet" href="~/css/productEdit.css">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">


<main id="container">
    <H2>Product Edit</H2>
    <section >
        <form class="product-form" action="/Product/Edit" method="POST">
            <div id="productDetail">
                <div >
                    <div class="form-group d-flex flex-column mb-3">
                        <label for="name">Name</label>
                        @Html.TextBoxFor(m => m.ProductName, new { @id = "name", @placeholder = "", @class = "form-control" })
                    </div>
                    <div class="price-qty">
                        <div class="form-group d-flex flex-column mb-3 ">
                            <label for="price">Price</label>
                            @Html.TextBoxFor(m => m.Price, new { @id = "price", @placeholder = "", @class = "form-control" })
                        </div>
                        <div class="form-group d-flex flex-column mb-3 ">
                            <label for="quantity">Quantity</label>
                            @Html.TextBoxFor(m => m.Quantity, new { @id = "quantity", @placeholder = "", @class = "form-control" })
                        </div>
                    </div>
                    <div class="form-group d-flex flex-column mb-3">
                        <label for="description">Description</label>
                        @Html.TextBoxFor(m => m.Description, new { @id = "description", @placeholder = "", @class = "form-control" })
                    </div>
                    <div class="form-group d-flex flex-column mb-3">
                        <label for="discount">Discount (%)</label>
                        @Html.TextBoxFor(m => m.Discount, new { @id = "discount", @placeholder = "", @class = "form-control" })
                    </div>
                    <div class="form-group d-flex flex-column mb-3">
                        <label for="colour">Colour</label>
                         <input type="text" id="colour" name="Colour" class="form-control" 
                                value="@(Model.Colors != null ? string.Join(", ", Model.Colors) : "")">
                          <!-- Dropdown to select predefined colors -->
                        <select id="colorDropdown" class="form-control mt-2">
                            <option value="">Select a color</option>
                            @foreach (var color in Model.ColorDropdown) 
                            {
                                <option value="@color.Categoryname">@color.Categoryname</option>
                            }
                        </select>
                    </div>
                    <div class="form-group d-flex flex-column mb-3">
                        <label for="size">Size</label>
                        <input type="text" id="size" name="Size" class="form-control" 
                                value="@(Model.Sizes != null ? string.Join(", ", Model.Sizes) : "")">
                    </div>
                    <div class="form-group d-flex flex-column mb-3">
                        <label for="category">Category</label>
                        <input type="text" id="category" name="Category" class="form-control" 
                                value="@(Model.Types != null ? string.Join(", ", Model.Types) : "")">
                    </div>
                    <div class="form-group d-flex flex-column mb-3">
                        <label for="properties">Properties</label>
                        <input type="text">
                    </div>
                </div>
                <div id="primaryImage">
                    <img src="https://picsum.photos/500/700?random=1" alt="primary image">
                </div>
            </div>
              <!-- Image Upload Section -->
            <section id="images" class="pt-5">
                <h3>IMAGES</h3>
                <table class="table">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Path</th>
                            <th scope="col">Is Primary?</th>
                            <th scope="col">Sort Order No.</th>
                            <th scope="col">Thumbnail</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody id="imageTableBody">
                        <!-- Existing rows will be here -->
                    </tbody>
                    <!-- Editable Input Row -->
                    <tfoot>
                        <tr id="addPhotoRow" style="display: none;">
                            <td><input type="text" id="photoName" name="photoName" placeholder="Enter Name" class="form-control" /></td>
                            <td><input type="file" id="imageFile" name="files" class="form-control" /></td>
                            <td><input type="checkbox" id="isPrimary" name="isPrimary" /></td>
                            <td><input type="number" id="sortOrder" name="sortOrder" placeholder="Sort Order" class="form-control" /></td>
                            <td><span id="thumbnailPreview"></span></td>
                            <td><i class="fas fa-trash-alt"></i></td>
                        </tr>
                    </tfoot>
                </table>
                <input type="hidden" name="productId" value="@Model.ID" />
                <button type="button" id="addPhotoBtn" class="">ADD NEW PHOTO</button>
            </section>

            <!-- SAVE & DELETE Buttons -->
            <div id="saveDelete">
                <button type="submit" class="">SAVE</button>
            </div>
        </form>
        
        <!-- Separate Delete Form -->
        <form action="/Product/Delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this product?');">
            <input type="hidden" name="productId" value="@Model.ID" />
            <button type="submit" class="btn btn-danger">DELETE</button>
        </form>
   
    </section>
   
    
</main>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const addPhotoBtn = document.getElementById("addPhotoBtn");
    const addPhotoRow = document.getElementById("addPhotoRow");
    const photoNameInput = document.getElementById("photoName");
    const photoPathInput = document.getElementById("photoPath");
    const isPrimaryInput = document.getElementById("isPrimary");
    const sortOrderInput = document.getElementById("sortOrder");
    const thumbnailPreview = document.getElementById("thumbnailPreview");
    const imageTableBody = document.getElementById("imageTableBody");

    // Show the editable row when "ADD NEW PHOTO" is clicked
    addPhotoBtn.addEventListener("click", () => {
        addPhotoRow.style.display = "table-row";
        photoNameInput.focus(); // Focus on the first input
    });

    // Update thumbnail preview dynamically
    photoPathInput.addEventListener("input", () => {
        const imagePath = photoPathInput.value;
        thumbnailPreview.innerHTML = imagePath ? `<img src="${imagePath}" alt="Thumbnail" width="50" />` : '';
    });

    // Handle input blur or pressing Enter to save the new photo
    const saveNewPhoto = () => {
        const photoName = photoNameInput.value;
        const photoPath = photoPathInput.value;
        const isPrimary = isPrimaryInput.checked;
        const sortOrder = sortOrderInput.value;

        // Validate required fields
        if (!photoName || !photoPath || !sortOrder) {
            alert("Please fill in all required fields.");
            return;
        }

        // Add the new photo row to the table
        const newRow = `
            <tr>
                <td>${photoName}</td>
                <td>${photoPath}</td>
                <td>${isPrimary ? "Yes" : "No"}</td>
                <td>${sortOrder}</td>
                <td><img src="${photoPath}" alt="${photoName}" width="50" /></td>
                <td>
                    <button class="btn btn-danger btn-sm deletePhoto">
                        <i class="fas fa-trash-alt"></i> Delete
                    </button>
                </td>
            </tr>
        `;
        imageTableBody.insertAdjacentHTML('beforeend', newRow);

        // Clear and hide the input row
        photoNameInput.value = "";
        photoPathInput.value = "";
        isPrimaryInput.checked = false;
        sortOrderInput.value = "";
        thumbnailPreview.innerHTML = "";
        addPhotoRow.style.display = "none";
    };

    // Save photo on input blur or Enter key press
    [photoNameInput, photoPathInput, sortOrderInput].forEach((input) => {
        input.addEventListener("blur", saveNewPhoto); // Save on blur
        input.addEventListener("keypress", (e) => {
            if (e.key === "Enter") {
                saveNewPhoto();
            }
        });
    });

    // Handle delete button click dynamically
    imageTableBody.addEventListener("click", (e) => {
        if (e.target.closest(".deletePhoto")) {
            const row = e.target.closest("tr");
            row.remove();

            // Optionally, send a request to delete the photo on the server
            // fetch('/YourEndpoint/DeleteImage', { method: 'DELETE', body: JSON.stringify({ id: photoId }) });
        }
    });
});
</script>